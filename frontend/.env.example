# Real auth backend base URL (required to switch from demo to real mode)
NEXT_PUBLIC_AUTH_PROVIDER_URL=https://your-auth-api.com

# OAuth client IDs used by the auth backend start endpoints
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
APPLE_CLIENT_ID=your_apple_service_id

# Optional backend secrets (used by your auth provider service)
GOOGLE_CLIENT_SECRET=your_google_secret
GITHUB_CLIENT_SECRET=your_github_secret
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
JWT_SECRET=your-super-secret-key
